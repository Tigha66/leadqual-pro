{
  "version": 2,
  "name": "leadqual-pro",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/src/app/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/src/app/$1"
    }
  ],
  "env": {
    "OPENAI_API_KEY": "@openai-api-key",
    "TAVILY_API_KEY": "@tavily-api-key",
    "FIRECRAWL_API_KEY": "@firecrawl-api-key",
    "DATABASE_URL": "@database-url"
  }
}
